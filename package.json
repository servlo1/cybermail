{
  "name": "cybermail",
  "version": "1.0.0",
  "description": "CyberMail – Cybersecurity-themed desktop email client",
  "main": "electron-main/index.js",
  "scripts": {
    "start": "concurrently \"npm run start:react\" \"npm run start:electron\"",
    "start:react": "cross-env BROWSER=none react-scripts start",
    "start:electron": "wait-on http://localhost:3000 && electron .",
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "build": "npm run build:react && electron-builder",
    "build:react": "react-scripts build",
    "dist": "npm run build:react && electron-builder --win",
    "test": "react-scripts test",
    "fix-native": "npx electron-rebuild -f -w better-sqlite3",
    "fix-db": "node scripts/fix-db.js"
  },
  "build": {
    "appId": "com.cybermail.app",
    "productName": "CyberMail",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "build/**/*",
      "electron-main/**/*",
      "imap-engine/**/*",
      "smtp-engine/**/*",
      "sync-worker/**/*",
      "database/**/*",
      "auth/**/*",
      "windows-manager/**/*",
      "services/**/*",
      "settings-api/**/*",
      "utils/**/*",
      "node_modules/**/*"
    ],
    "nativeRebuilder": "legacy"
  },
  "dependencies": {
    "better-sqlite3": "^9.6.0",
    "electron-store": "^8.2.0",
    "imap": "^0.8.19",
    "mailparser": "^3.7.1",
    "nodemailer": "^6.9.14",
    "node-imap": "^0.9.6",
    "electron-updater": "^6.3.9",
    "keytar": "^7.9.0",
    "uuid": "^9.0.1",
    "mime-types": "^2.1.35",
    "sanitize-html": "^2.13.0",
    "cheerio": "^1.0.0",
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-scripts": "5.0.1",
    "react-router-dom": "^6.26.2",
    "zustand": "^4.5.5",
    "@tiptap/react": "^2.7.2",
    "@tiptap/starter-kit": "^2.7.2",
    "@tiptap/extension-underline": "^2.7.2",
    "@tiptap/extension-link": "^2.7.2",
    "@tiptap/extension-placeholder": "^2.7.2",
    "react-virtuoso": "^4.10.4",
    "date-fns": "^3.6.0",
    "dompurify": "^3.1.6",
    "electron-log": "^5.2.0",
    "bindings": "^1.5.0"
  },
  "devDependencies": {
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "wait-on": "^7.2.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version"
    ]
  }
}